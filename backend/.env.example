# ── BashForge Backend .env  ───────────────────────────────────────
# Copy to .env and fill in values

# Redis
REDIS_URL=redis://redis:6379/0

# Session
SESSION_TTL_SECONDS=3600
MAX_CONCURRENT_SESSIONS=20

# Kubernetes
K8S_NAMESPACE=bashforge-sessions
K8S_SANDBOX_IMAGE=bashforge/sandbox:latest
KUBECONFIG_PATH=
K8S_NODE_IP=

# Security
COOKIE_SECRET=CHANGE_ME_32_CHARS_MINIMUM_PLEASE
SECURE_COOKIES=false

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# App
DEBUG=true
MOCK_K8S=true
